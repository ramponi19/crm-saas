# Supabase — projeto principal
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
# CRÍTICO: deve estar disponível no runtime do servidor (não apenas no build).
# No Vercel: Settings → Environment Variables → marcar "Server" (não só "Build").
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# SEGURANÇA
# ─────────────────────────────────────────────────────────────────

# Chave para criptografia AES-256-GCM das credenciais de pagamento dos tenants.
# Gerar: openssl rand -hex 32
# Formato aceito: 64 hex chars (32 bytes) ou base64 de 32 bytes.
# CRÍTICO: sem esta variável, nenhuma credencial de pagamento pode ser salva/lida.
PAYMENT_ENCRYPTION_KEY=

# Segredo compartilhado entre Vercel Cron e a rota /api/cron/[job].
# Gerar: openssl rand -hex 32
# CRÍTICO: sem esta variável, a rota /api/cron/* retorna 401 para qualquer chamada.
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────
# PAGAMENTOS — deixar em branco para desativar (modo "em breve")
# Preencher apenas quando escolher a plataforma de cobrança.
#
# Plataformas testadas:
#   Stripe      → stripe.com          (internacional, aceita BRL)
#   Asaas       → asaas.com           (BR, PIX + boleto + cartão)
#   PagSeguro   → pagseguro.uol.com.br
#   Abacatepay  → abacatepay.com      (PIX nativo)
#
# Para ativar: preencha as variáveis abaixo e redeploy.
# Para desativar: deixe em branco — a página /planos mostra "Em breve".
#
# Nota: STRIPE_PRICE_STARTER / STRIPE_PRICE_PRO foram removidas.
# Os price IDs do Stripe agora vêm de planos_config.stripe_price_id (DB).
# ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
